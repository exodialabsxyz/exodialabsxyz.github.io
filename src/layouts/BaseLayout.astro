---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	type?: string;
}

const isDev = import.meta.env.DEV;
const { 
	title, 
	description = "Exodia Labs - Strategic Research Lab focusing on AI and Cybersecurity",
	image = "/og-image.jpg", 
	imageAlt,
	type = "website"
} = Astro.props;

const siteURL = Astro.site || new URL('https://exodialabs.xyz');
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const socialImageURL = new URL(image, siteURL);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title} | Exodia Labs</title>
		<meta name="title" content={`${title} | Exodia Labs`} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content="Exodia Labs" />
		<meta property="og:title" content={`${title} | Exodia Labs`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />
		<meta property="og:image:type" content={image.endsWith('.webp') ? 'image/webp' : 'image/jpeg'} />
		<meta property="og:image:alt" content={imageAlt || title} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:site" content="@alegpmbt" />
		<meta name="twitter:creator" content="@alegpmbt" />
		<meta name="twitter:title" content={`${title} | Exodia Labs`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageURL} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

		<script is:inline>
			const theme = localStorage.getItem('theme') || 'aurora';
			document.documentElement.setAttribute('data-theme', theme);
		</script>
	</head>
	<body class="min-h-screen flex flex-col relative">
		<!-- Noise overlay -->
		<div class="pointer-events-none fixed inset-0 z-50 h-full w-full opacity-[0.03]">
			<svg class="absolute inset-0 h-full w-full" xmlns="http://www.w3.org/2000/svg">
				<filter id="noiseFilter">
					<feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
				</filter>
				<rect width="100%" height="100%" filter="url(#noiseFilter)" />
			</svg>
		</div>

		<header id="main-header" class="py-4 px-4 md:px-8 flex justify-between items-center bg-bg-primary/80 sticky top-0 z-50 backdrop-blur-md transition-transform duration-300">
			<a href="/" class="flex items-center gap-2.5 group whitespace-nowrap relative z-50">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="square" stroke-linejoin="round" class="w-6 h-6 md:w-7 md:h-7 text-primary transition-transform duration-300 group-hover:scale-105">
					<line x1="20" y1="20" x2="20" y2="80" />
					<path d="M 20 20 L 45 20 L 80 80" />
					<path d="M 20 80 L 45 80 L 80 20" />
				</svg>
				<span class="text-lg md:text-xl font-serif font-bold tracking-tight text-primary group-hover:opacity-80 transition-colors">
					EXODIA LABS
				</span>
			</a>
			
			<!-- Desktop Navigation -->
			<nav class="hidden md:flex gap-8 text-sm font-medium tracking-wide">
				<a href="/projects" class="hover:text-primary transition-colors whitespace-nowrap">PROJECTS</a>
				<a href="/blog" class="hover:text-primary transition-colors whitespace-nowrap">PUBLICATIONS</a>
				<a href="/about" class="hover:text-primary transition-colors whitespace-nowrap">ABOUT</a>
			</nav>

			<!-- Mobile Hamburger Button -->
			<button id="mobile-menu-btn" class="md:hidden relative z-50 p-2 -mr-2 text-text-primary focus:outline-none" aria-label="Toggle menu">
				<svg id="icon-menu" class="w-6 h-6 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<svg id="icon-close" class="w-6 h-6 transition-transform duration-300 absolute top-2 left-2 opacity-0 scale-50" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</header>

		<!-- Mobile Menu Overlay -->
		<div id="mobile-menu-overlay" class="fixed inset-0 bg-bg-primary/95 backdrop-blur-xl z-40 opacity-0 pointer-events-none transition-opacity duration-300 flex flex-col justify-center items-center">
			<nav class="flex flex-col gap-8 text-center text-3xl font-serif">
				<a href="/projects" class="mobile-link hover:text-primary transition-colors">Projects</a>
				<a href="/blog" class="mobile-link hover:text-primary transition-colors">Publications</a>
				<a href="/about" class="mobile-link hover:text-primary transition-colors">About</a>
			</nav>
			<div class="absolute bottom-12 flex gap-6 text-xs font-mono tracking-widest text-text-secondary uppercase">
				<a href="https://github.com/exodialabsxyz" class="hover:text-primary transition-colors">GITHUB</a>
				<a href="https://x.com/alegpmbt" class="hover:text-primary transition-colors">TWITTER</a>
			</div>
		</div>

		<main class="flex-grow">
			<slot />
		</main>

		<footer class="py-12 px-8 bg-bg-secondary/10">
			<div class="max-w-7xl mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] font-mono tracking-widest text-text-secondary uppercase">
					<div class="flex gap-8">
						<a href="https://github.com/exodialabsxyz" class="hover:text-primary transition-colors">GITHUB</a>
						<a href="https://x.com/alegpmbt" class="hover:text-primary transition-colors">TWITTER</a>
						<a href="/about" class="hover:text-primary transition-colors">LAB_INFO</a>
					</div>
					<p>© 2026 EXODIA LABS</p>
				</div>
			</div>
		</footer>

		<script>
			let lastScrollY = window.scrollY;
			const header = document.getElementById('main-header');
			const mobileMenuBtn = document.getElementById('mobile-menu-btn');
			const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
			const iconMenu = document.getElementById('icon-menu');
			const iconClose = document.getElementById('icon-close');
			let isMobileMenuOpen = false;

			// Handle Mobile Menu Toggle
			if (mobileMenuBtn && mobileMenuOverlay && iconMenu && iconClose) {
				const toggleMenu = () => {
					isMobileMenuOpen = !isMobileMenuOpen;
					
					if (isMobileMenuOpen) {
						// Open menu
						mobileMenuOverlay.classList.remove('opacity-0', 'pointer-events-none');
						mobileMenuOverlay.classList.add('opacity-100', 'pointer-events-auto');
						
						iconMenu.classList.add('opacity-0', 'scale-50');
						iconMenu.classList.remove('opacity-100', 'scale-100');
						
						iconClose.classList.remove('opacity-0', 'scale-50');
						iconClose.classList.add('opacity-100', 'scale-100');
						
						document.body.style.overflow = 'hidden'; // Prevent scrolling
					} else {
						// Close menu
						mobileMenuOverlay.classList.add('opacity-0', 'pointer-events-none');
						mobileMenuOverlay.classList.remove('opacity-100', 'pointer-events-auto');
						
						iconClose.classList.add('opacity-0', 'scale-50');
						iconClose.classList.remove('opacity-100', 'scale-100');
						
						iconMenu.classList.remove('opacity-0', 'scale-50');
						iconMenu.classList.add('opacity-100', 'scale-100');
						
						document.body.style.overflow = ''; // Restore scrolling
					}
				};

				mobileMenuBtn.addEventListener('click', toggleMenu);

				// Close menu when a link is clicked
				const mobileLinks = document.querySelectorAll('.mobile-link');
				mobileLinks.forEach(link => {
					link.addEventListener('click', () => {
						if (isMobileMenuOpen) toggleMenu();
					});
				});
			}

			// Handle Header Hide/Show on Scroll
			window.addEventListener('scroll', () => {
				if (header && !isMobileMenuOpen) { // Don't hide header if mobile menu is open
					if (window.scrollY > lastScrollY && window.scrollY > 100) {
						// Scrolling down
						header.style.transform = 'translateY(-100%)';
					} else {
						// Scrolling up
						header.style.transform = 'translateY(0)';
					}
					lastScrollY = window.scrollY;
				}
			});
		</script>
		{isDev && <ThemeSwitcher />}
	</body>
</html>
