---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';

export async function getStaticPaths() {
	const researchEntries = await getCollection('research');
	return researchEntries.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const author = await getEntry(entry.data.author);

let ogImage = entry.data.image;
if (typeof entry.data.image !== 'string' && entry.data.image) {
	const optimized = await getImage({ src: entry.data.image as any, format: 'webp', width: 1200, quality: 80 });
	ogImage = optimized.src;
}
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={ogImage}>
	<article class="max-w-4xl mx-auto py-24 px-8">
		<header class="mb-16 border-b border-border pb-16">
			<h1 class="text-5xl md:text-6xl font-serif font-bold mb-8 leading-tight">{entry.data.title}</h1>
			<p class="text-xl text-text-secondary leading-relaxed italic mb-12">{entry.data.description}</p>

			<div class="flex flex-wrap items-center gap-4 mb-12">
				{author?.data.avatar && (
					<img 
						src={author.data.avatar} 
						alt={author.data.name}
						class="w-10 h-10 rounded-full border border-border grayscale"
					/>
				)}
				<div class="flex flex-col">
					<span class="text-[10px] font-mono text-text-secondary uppercase tracking-widest">BY {author?.data.name}</span>
					<time class="text-xs font-mono text-primary">
						{entry.data.publishDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						})}
					</time>
				</div>
			</div>
			
			{entry.data.image && (
				<div class="mb-12 aspect-[21/9] overflow-hidden border border-border rounded-xl">
					<img 
						src={entry.data.image} 
						alt={entry.data.imageAlt || entry.data.title}
						class="w-full h-full object-cover transition-all duration-700"
					/>
				</div>
			)}
		</header>

		<div class="prose">
			<Content />
		</div>

		<footer class="mt-16 pt-8 flex justify-between items-center">
			<a href="/research" class="text-xs font-mono text-primary hover:gap-4 flex items-center gap-2 transition-all">
				← BACK TO RESEARCH
			</a>
			<div class="flex gap-4">
				{entry.data.tags.map(tag => (
					<span class="text-[10px] font-mono text-text-secondary border border-border px-2 py-1 uppercase tracking-widest">{tag}</span>
				))}
			</div>
		</footer>
	</article>
</BaseLayout>
