---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
	const isProd = import.meta.env.PROD;
	const blogEntries = await getCollection('blog', ({ data }) => {
		return isProd ? !data.draft : true;
	});
	return blogEntries.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const author = await getEntry(entry.data.author);
---

	<BaseLayout 
		title={entry.data.title} 
		description={entry.data.description}
		image={typeof entry.data.image === 'string' ? entry.data.image : entry.data.image?.src}
		imageAlt={entry.data.imageAlt || entry.data.title}
		type="article"
	>
	<!-- Reading Progress Bar -->
	<div id="progress-container" class="fixed top-0 left-0 w-full h-1 z-[60] pointer-events-none">
		<div id="progress-bar" class="h-full bg-primary w-0 transition-all duration-150"></div>
	</div>

	<article class="max-w-4xl mx-auto py-24 px-8">
		<header class="mb-16">
			<h1 class="text-5xl md:text-6xl font-serif font-bold mb-8 leading-tight">{entry.data.title}</h1>
			<p class="text-xl text-text-secondary leading-relaxed italic mb-12">{entry.data.description}</p>

			<div class="flex items-center gap-4 mb-12">
				{author?.data.avatar && (
					<div class="w-10 h-10 rounded-full border border-border flex items-center justify-center bg-bg-secondary/50">
						<img 
							src={author.data.avatar} 
							alt={author.data.name}
							class="w-6 h-6 object-contain"
						/>
					</div>
				)}
				<div class="flex flex-col">
					<span class="text-[10px] font-mono text-text-secondary uppercase tracking-widest">BY {author?.data.name}</span>
					<time class="text-xs font-mono text-primary">
						{entry.data.publishDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						})}
					</time>
				</div>
			</div>

			{entry.data.image && (
				<div class="mb-12 overflow-hidden border border-border rounded-xl">
					<Image 
						src={entry.data.image} 
						alt={entry.data.imageAlt || entry.data.title}
						class="w-full h-auto object-contain transition-all duration-700"
						format="webp"
						quality="high"
					/>
				</div>
			)}
		</header>

		<div class="max-w-none">
			<TableOfContents headings={headings} />
			
			<div class="prose">
				<Content />
			</div>
		</div>

		<RelatedPosts currentSlug={entry.slug} tags={entry.data.tags} />
	</article>

	<script>
		const progressBar = document.getElementById('progress-bar');
		
		window.addEventListener('scroll', () => {
			const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
			const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
			const scrolled = (winScroll / height) * 100;
			
			if (progressBar) {
				progressBar.style.width = scrolled + "%";
			}
		});
	</script>
</BaseLayout>
